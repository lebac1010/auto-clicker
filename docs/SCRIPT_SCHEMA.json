{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/auto-clicker/script.schema.json",
  "title": "Auto Clicker Script",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "type",
    "createdAt",
    "updatedAt",
    "coordinateMode",
    "screen",
    "loop",
    "defaults",
    "steps"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "type": { "enum": ["single_tap", "multi_tap", "swipe", "macro"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "coordinateMode": { "enum": ["normalized", "absolute_px"] },
    "screen": { "$ref": "#/$defs/screen" },
    "loop": { "$ref": "#/$defs/loop" },
    "defaults": { "$ref": "#/$defs/defaults" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "conditions": { "$ref": "#/$defs/conditions" },
    "metadata": { "$ref": "#/$defs/metadata" }
  },
  "allOf": [
    {
      "if": { "properties": { "coordinateMode": { "const": "normalized" } } },
      "then": {
        "properties": {
          "steps": {
            "items": { "$ref": "#/$defs/stepNormalized" }
          }
        }
      }
    },
    {
      "if": { "properties": { "coordinateMode": { "const": "absolute_px" } } },
      "then": {
        "properties": {
          "steps": {
            "items": { "$ref": "#/$defs/stepAbsolute" }
          }
        }
      }
    }
  ],
  "$defs": {
    "screen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["widthPx", "heightPx", "densityDpi", "rotation", "insets"],
      "properties": {
        "widthPx": { "type": "integer", "minimum": 1 },
        "heightPx": { "type": "integer", "minimum": 1 },
        "densityDpi": { "type": "integer", "minimum": 1 },
        "rotation": { "enum": [0, 90, 180, 270] },
        "insets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["topPx", "bottomPx", "leftPx", "rightPx"],
          "properties": {
            "topPx": { "type": "integer", "minimum": 0 },
            "bottomPx": { "type": "integer", "minimum": 0 },
            "leftPx": { "type": "integer", "minimum": 0 },
            "rightPx": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "loop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["infinite", "count", "duration"] },
        "count": { "type": ["integer", "null"], "minimum": 1 },
        "durationMs": { "type": ["integer", "null"], "minimum": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "count" } } },
          "then": { "required": ["count"] }
        },
        {
          "if": { "properties": { "mode": { "const": "duration" } } },
          "then": { "required": ["durationMs"] }
        }
      ]
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intervalMs", "holdMs", "jitterPx", "randomDelayMsMin", "randomDelayMsMax"],
      "properties": {
        "intervalMs": { "type": "integer", "minimum": 1 },
        "holdMs": { "type": "integer", "minimum": 0 },
        "jitterPx": { "type": "integer", "minimum": 0 },
        "randomDelayMsMin": { "type": "integer", "minimum": 0 },
        "randomDelayMsMax": { "type": "integer", "minimum": 0 }
      }
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireForegroundApp": { "type": ["string", "null"] },
        "requireScreenOn": { "type": ["boolean", "null"] },
        "minBatteryPct": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "timeWindow": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
            "end": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },
    "step": {
      "oneOf": [
        { "$ref": "#/$defs/stepTap" },
        { "$ref": "#/$defs/stepLongPress" },
        { "$ref": "#/$defs/stepSwipe" },
        { "$ref": "#/$defs/stepWait" }
      ]
    },
    "stepBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "enabled"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "enabled": { "type": "boolean" },
        "label": { "type": "string" },
        "intervalMs": { "type": "integer", "minimum": 0 },
        "durationMs": { "type": "integer", "minimum": 0 }
      }
    },
    "stepTap": {
      "allOf": [
        { "$ref": "#/$defs/stepBase" },
        {
          "properties": {
            "type": { "const": "tap" },
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "required": ["x", "y"]
        }
      ]
    },
    "stepLongPress": {
      "allOf": [
        { "$ref": "#/$defs/stepBase" },
        {
          "properties": {
            "type": { "const": "long_press" },
            "x": { "type": "number" },
            "y": { "type": "number" },
            "durationMs": { "type": "integer", "minimum": 1 }
          },
          "required": ["x", "y", "durationMs"]
        }
      ]
    },
    "stepSwipe": {
      "allOf": [
        { "$ref": "#/$defs/stepBase" },
        {
          "properties": {
            "type": { "const": "swipe" },
            "x": { "type": "number" },
            "y": { "type": "number" },
            "x2": { "type": "number" },
            "y2": { "type": "number" },
            "durationMs": { "type": "integer", "minimum": 1 }
          },
          "required": ["x", "y", "x2", "y2", "durationMs"]
        }
      ]
    },
    "stepWait": {
      "allOf": [
        { "$ref": "#/$defs/stepBase" },
        {
          "properties": {
            "type": { "const": "wait" },
            "durationMs": { "type": "integer", "minimum": 1 }
          },
          "required": ["durationMs"]
        }
      ]
    },
    "stepNormalized": {
      "allOf": [
        { "$ref": "#/$defs/step" },
        {
          "properties": {
            "x": { "type": "number", "minimum": 0, "maximum": 1 },
            "y": { "type": "number", "minimum": 0, "maximum": 1 },
            "x2": { "type": "number", "minimum": 0, "maximum": 1 },
            "y2": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      ]
    },
    "stepAbsolute": {
      "allOf": [
        { "$ref": "#/$defs/step" },
        {
          "properties": {
            "x": { "type": "number", "minimum": 0 },
            "y": { "type": "number", "minimum": 0 },
            "x2": { "type": "number", "minimum": 0 },
            "y2": { "type": "number", "minimum": 0 }
          }
        }
      ]
    }
  }
}
